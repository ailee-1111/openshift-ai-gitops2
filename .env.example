# 이 파일을 .env로 복사 후 값을 채우세요. .env 자체는 gitignored.
#   cp .env.example .env

# ─────────────────────────────────────────────
# 클러스터 접속
# ─────────────────────────────────────────────
KUBECONFIG=/absolute/path/to/kubeconfig
CLUSTER_DOMAIN=apps.example.cluster.com
CLUSTER_API_URL=https://api.example.cluster.com:6443

# pull-secret (필요 시)
PULL_SECRET_PATH=/absolute/path/to/pull-secret.json

# ─────────────────────────────────────────────
# 환경 모드
#   CONNECTED : 외부망 접근 가능, AI 도구 사용 가능
#   AIRGAP    : 외부망 단절, 사람이 runbook만 실행
# ─────────────────────────────────────────────
OCP_AI_ENV_MODE=CONNECTED

# 환경 식별자 (DEV|PROD)
OCP_AI_ENV=DEV

# ─────────────────────────────────────────────
# Git 원격
#   CONNECTED: GITHUB_REMOTE 사용
#   AIRGAP   : GITEA_REMOTE 사용 (외장 SSD 경유로 미리 push됨)
# ─────────────────────────────────────────────
GITHUB_REMOTE=git@github.com:org/openshift-ai-gitops.git
GITEA_REMOTE=git@gitea.internal:org/openshift-ai-gitops.git
GIT_BRANCH=main

# ArgoCD가 실제로 참조할 원격 (위 둘 중 하나를 복사)
GIT_REMOTE_URL=${GITHUB_REMOTE}

# ─────────────────────────────────────────────
# 레지스트리
#   QUAY_REGISTRY              : 운영/공유 이미지용 (Quay on OpenShift)
#   OPENSHIFT_INTERNAL_REGISTRY : 클러스터 내부 기본 레지스트리
#   AIRGAP_MIRROR_REGISTRY     : oc-mirror 목적지 (Air-gap에서만 유효)
# ─────────────────────────────────────────────
QUAY_REGISTRY=quay.apps.example.cluster.com
OPENSHIFT_INTERNAL_REGISTRY=image-registry.openshift-image-registry.svc:5000
AIRGAP_MIRROR_REGISTRY=mirror.apps.airgap.cluster.com

# ─────────────────────────────────────────────
# Air-gap 부트스트랩(1회성)
#   OC_MIRROR_WORKSPACE : oc-mirror 실행 워크스페이스 (외장 SSD 마운트 경로)
# ─────────────────────────────────────────────
OC_MIRROR_WORKSPACE=/Volumes/airgap-ssd/oc-mirror

# ─────────────────────────────────────────────
# PoC 시나리오 선택
#   쉼표 구분, 해당 시나리오만 deploy/validate 대상
#   전체: S1,S2,S3,S4,S5,S6,S7,S8,S9,S10
# ─────────────────────────────────────────────
SCENARIOS=S1,S2,S3,S4,S5,S6

# ─────────────────────────────────────────────
# PoC 네임스페이스 / 모델
# ─────────────────────────────────────────────
POC_NAMESPACE=rhoai-poc
MODEL_NS=rhoai-poc
MODEL_REGISTRY_NS=rhoai-model-registries
MODEL_NAME=smollm2-135m
S3_BUCKET=models
S3_MODEL_PATH=smollm2-135m/v1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─────────────────────────────────────────────
# 알림 (S6/S2 파이프라인)
# ─────────────────────────────────────────────
ALERT_EMAIL_TO=poc-admin@example.com
ALERT_EMAIL_FROM=ocp-alert@example.com

# ─────────────────────────────────────────────
# GPU 설정
#   none  : GPU 없는 클러스터 — GPU 관련 리소스 스킵
#   L40S  : NVIDIA L40S
#   A100  : NVIDIA A100
#   H200  : NVIDIA H200 (HGX)
#   A40   : NVIDIA A40
#   auto  : oc 명령으로 자동 감지 (preflight에서 설정)
# ─────────────────────────────────────────────
GPU=auto

# ─────────────────────────────────────────────
# GPU 스펙 상세 (런북 이식성 지원)
#   환경별 기본값:
#     Sandbox : GPU_TYPE=L40S, GPU_COUNT=4, GPU_VRAM_GB=48
#     Mobis   : GPU_TYPE=H200, GPU_COUNT=8, GPU_VRAM_GB=141
# ─────────────────────────────────────────────
GPU_TYPE="${GPU_TYPE:-auto}"
GPU_COUNT="${GPU_COUNT:-1}"
GPU_VRAM_GB="${GPU_VRAM_GB:-48}"
GPU_MEMORY_REQUEST="${GPU_MEMORY_REQUEST:-4Gi}"
GPU_MEMORY_LIMIT="${GPU_MEMORY_LIMIT:-8Gi}"

# ─────────────────────────────────────────────
# 성능 임계값 (모델 크기·GPU에 따라 조정)
# ─────────────────────────────────────────────
COLD_START_TIMEOUT="${COLD_START_TIMEOUT:-120}"
VLLM_TIMEOUT="${VLLM_TIMEOUT:-600}"

# ─────────────────────────────────────────────
# 스토리지 / 노드 구성
#   AWS    : STORAGE_CLASS=gp3-csi
#   Bare metal : STORAGE_CLASS=lvms-vg1
# ─────────────────────────────────────────────
STORAGE_CLASS="${STORAGE_CLASS:-gp3-csi}"
NODE_COUNT="${NODE_COUNT:-6}"
WORKER_GPU_NODES="${WORKER_GPU_NODES:-1}"

# ─────────────────────────────────────────────
# 토크나이저 모델 (Guardrails, PII 등에서 참조)
# ─────────────────────────────────────────────
TOKENIZER_MODEL="${TOKENIZER_MODEL:-HuggingFaceTB/SmolLM2-135M}"

# ─────────────────────────────────────────────
# 고객/PoC 식별자 (태깅, 리포트용)
# ─────────────────────────────────────────────
CUSTOMER=default

# ─────────────────────────────────────────────
# OpenShift 버전 (mirror-list에서 사용)
# ─────────────────────────────────────────────
OCP_VERSION=4.21
