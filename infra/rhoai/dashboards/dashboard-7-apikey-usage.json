{"apiVersion": "perses.dev/v1alpha2", "kind": "PersesDashboard", "metadata": {"annotations": {"opendatahub.io/dashboard-feature-visibility": "[]"}, "labels": {"app.kubernetes.io/part-of": "dashboard", "app.opendatahub.io/dashboard": "true"}, "name": "dashboard-7-apikey-usage", "namespace": "redhat-ods-monitoring"}, "spec": {"config": {"display": {"description": "API Key\ubcc4 \ud1a0\ud070 \uc0ac\uc6a9\ub7c9 \ubc0f \uc694\uccad \ubd84\uc11d", "name": "API Key Usage"}, "duration": "1h", "layouts": [{"kind": "Grid", "spec": {"display": {"title": "Overview"}, "items": [{"content": {"$ref": "#/spec/panels/stat_total_tokens"}, "height": 4, "width": 6, "x": 0, "y": 0}, {"content": {"$ref": "#/spec/panels/stat_total_requests"}, "height": 4, "width": 6, "x": 6, "y": 0}, {"content": {"$ref": "#/spec/panels/stat_active_users"}, "height": 4, "width": 6, "x": 12, "y": 0}, {"content": {"$ref": "#/spec/panels/stat_active_subs"}, "height": 4, "width": 6, "x": 18, "y": 0}]}}, {"kind": "Grid", "spec": {"display": {"title": "\uc0ac\uc6a9\uc790\ubcc4 \uc0ac\uc6a9\ub7c9"}, "items": [{"content": {"$ref": "#/spec/panels/tokens_by_user"}, "height": 8, "width": 12, "x": 0, "y": 0}, {"content": {"$ref": "#/spec/panels/requests_by_user"}, "height": 8, "width": 12, "x": 12, "y": 0}]}}, {"kind": "Grid", "spec": {"display": {"title": "Route\ubcc4 \uc0ac\uc6a9\ub7c9"}, "items": [{"content": {"$ref": "#/spec/panels/tokens_by_route"}, "height": 8, "width": 12, "x": 0, "y": 0}, {"content": {"$ref": "#/spec/panels/tokens_by_subscription"}, "height": 8, "width": 12, "x": 12, "y": 0}]}}, {"kind": "Grid", "spec": {"display": {"title": "\uc0ac\uc6a9\ub7c9 \ucd94\uc774"}, "items": [{"content": {"$ref": "#/spec/panels/tokens_rate"}, "height": 8, "width": 24, "x": 0, "y": 0}]}}], "panels": {"requests_by_user": {"kind": "Panel", "spec": {"display": {"name": "\uc0ac\uc6a9\uc790\ubcc4 \uc694\uccad"}, "plugin": {"kind": "TimeSeriesChart", "spec": {"legend": {"mode": "list", "position": "bottom"}}}, "queries": [