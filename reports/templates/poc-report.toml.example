# ============================================================
# RHOAI PoC 검증 결과 보고서 — TOML 데이터 템플릿
# ============================================================
# 사용법:
#   1. 이 파일을 복사하여 고객명으로 저장 (예: acme.toml)
#   2. 각 섹션의 값을 PoC 결과에 맞게 수정
#   3. python generate.py acme.toml -o acme-report.html
#   4. python generate.py acme.toml --variant dashboard -o dashboard.html
# ============================================================

# ─── 템플릿 설정 ──────────────────────────────────────────
[template]
# variant: full | enterprise | print | dashboard | presentation | technical | operations
variant = "full"
# 포함할 섹션 (빈 배열이면 variant 기본값 사용)
sections = []
# 테마: auto | light | dark
theme = "auto"

# ─── 보고서 메타정보 ───────────────────────────────────────
[meta]
title           = "PoC 검증 결과 보고서"
badge           = "Red Hat OpenShift AI"
customer        = "Customer (현대모비스)"
subtitle        = "AI/LLM 플랫폼 구축 검증"
poc_period      = "2026-05 ~ 06"
ocp_version     = "OCP 4.21.14"
gpu_spec        = "GPU: L40S x 4"
rhoai_version   = "RHOAI 3.4.0 GA"
report_date     = "2026-05-17"
footer          = "Red Hat OpenShift AI PoC — Customer | 2026-05-17 | OCP 4.21.14 | RHOAI 3.4.0 GA"

# [개선] 변경 이력 추적
[[meta.revisions]]
version = "1.0"
date    = "2026-05-15"
author  = "PoC Team"
summary = "초기 보고서 작성 (v2 Phase A~C 결과)"

[[meta.revisions]]
version = "2.0"
date    = "2026-05-17"
author  = "PoC Team"
summary = "v3 시나리오 강화, 전체 100% 달성"

# ─── Executive Summary ────────────────────────────────────
[summary]
total_coverage_pct   = 100
total_target         = 79
total_label          = "79개 대상 전부 검증 완료"
scenario_pass_pct    = 100
scenario_pass_label  = "S1~S6 52개 전부 PASS"
verified_count       = 79
verified_label       = "SKIP 0 / 조건부 0 / 부분 0"
operator_count       = 20
operator_label       = "전체 Succeeded, DSC Ready"

[[summary.coverage_table]]
category    = "시나리오 (S1~S6)"
total       = 52
verified    = 52
conditional = 0
skip        = 0
coverage    = "100%"
status      = "pass"

[[summary.coverage_table]]
category    = "Exploratory"
total       = 27
verified    = 27
conditional = 0
skip        = 0
coverage    = "100%"
status      = "pass"

[[summary.coverage_table]]
category    = "Out-of-scope"
total       = 6
verified    = "--"
conditional = "--"
skip        = "--"
coverage    = "N/A"
status      = "skip"

[[summary.coverage_table]]
category    = "**합계**"
total       = 85
verified    = 79
conditional = 0
skip        = 0
coverage    = "100%"
status      = "pass"
bold        = true

# [개선] SLA/SLO 목표 정의
[[summary.sla_targets]]
metric    = "Pod 복구 시간"
target    = "< 300초"
actual    = "66초"
status    = "pass"
margin    = "78%"

[[summary.sla_targets]]
metric    = "Cold Start"
target    = "< 120초"
actual    = "61~73초"
status    = "pass"
margin    = "39~49%"

[[summary.sla_targets]]
metric    = "RollingUpdate 실패율"
target    = "< 10%"
actual    = "0%"
status    = "pass"
margin    = "100%"

[[summary.sla_targets]]
metric    = "API 가용률"
target    = "> 99.9%"
actual    = "100%"
status    = "pass"
margin    = "0.1%+"

