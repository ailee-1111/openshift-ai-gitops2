# ─── GPU 비용 할당 ───────────────────────────────────────
[cost_allocation]
allocation_model = "Namespace"
gpu_pricing = "시간당"
collection_interval = "15초"

[[cost_allocation.layers]]
level = "L1 팀"
basis = "Namespace"
metric = "DCGM_FI_DEV_GPU_UTIL by namespace"
method = "Prometheus recording rule + Perses 대시보드"

[[cost_allocation.layers]]
level = "L2 모델"
basis = "InferenceService label"
metric = "vllm:num_requests_running by model"
method = "ServiceMonitor label selector"

[[cost_allocation.layers]]
level = "L3 사용자"
basis = "MaaS API Key"
metric = "maas_api_requests_total by key"
method = "Kuadrant RateLimitPolicy counter"

[[cost_allocation.kueue_queues]]
queue = "high-priority"
gpu_alloc = "GPU 2기"
preemption = "선점 가능"
target_team = "프로덕션 서빙"

[[cost_allocation.kueue_queues]]
queue = "normal"
gpu_alloc = "GPU 1기"
preemption = "선점 당할 수 있음"
target_team = "개발/테스트"

[[cost_allocation.kueue_queues]]
queue = "batch"
gpu_alloc = "남은 GPU"
preemption = "최하 우선순위"
target_team = "TrainJob/LMEval"
